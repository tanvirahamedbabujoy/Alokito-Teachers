                <div><h4 class="font-semibold text-white text-sm mb-4">Programs</h4><ul class="space-y-2.5"><li><a href="#programs" class="text-white/50 text-sm hover:text-white transition-colors">Alokito Future Teachers</a></li><li><a href="#programs" class="text-white/50 text-sm hover:text-white transition-colors">Subject Expert Training</a></li><li><a href="#programs" class="text-white/50 text-sm hover:text-white transition-colors">Teachers Plan Modules</a></li><li><a href="#choose" class="text-white/50 text-sm hover:text-white transition-colors">Diploma Package</a></li><li><a href="#customize" class="text-white/50 text-sm hover:text-white transition-colors">Customize Learning</a></li></ul></div>
                <div><h4 class="font-semibold text-white text-sm mb-4">Company</h4><ul class="space-y-2.5"><li><a href="#" class="text-white/50 text-sm hover:text-white transition-colors">About Us</a></li><li><a href="#" class="text-white/50 text-sm hover:text-white transition-colors">Partner Schools</a></li><li><a href="#" class="text-white/50 text-sm hover:text-white transition-colors">Careers</a></li><li><a href="#" class="text-white/50 text-sm hover:text-white transition-colors">Blog</a></li><li><a href="#" class="text-white/50 text-sm hover:text-white transition-colors">Contact</a></li></ul></div>
            </div>
            <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4"><p class="text-white/30 text-xs">© 2025 Alokito Teachers. All rights reserved.</p><div class="flex gap-6"><a href="#" class="text-white/30 text-xs hover:text-white/60 transition-colors">Privacy Policy</a><a href="#" class="text-white/30 text-xs hover:text-white/60 transition-colors">Terms of Service</a></div></div>
        </div>
    </footer>

    <!-- Floating Button -->
    <div id="float-btn" class="float-btn fixed bottom-6 right-6 z-50"><button onclick="openModal()" class="bg-gradient-to-r from-accent-orange to-accent-gold text-white font-bold px-6 py-3.5 rounded-2xl shadow-xl shadow-accent-orange/30 hover:shadow-2xl hover:shadow-accent-orange/40 transition-all flex items-center gap-2 text-sm"><i data-lucide="send" class="w-4 h-4"></i> Apply Now</button></div>

    <script>
    lucide.createIcons();
    const navbar=document.getElementById('navbar');
    window.addEventListener('scroll',()=>{const s=window.scrollY;navbar.classList.toggle('nav-blur',s>50);navbar.classList.toggle('bg-white/80',s>50);navbar.classList.toggle('border-b',s>50);navbar.classList.toggle('border-warm-border/50',s>50);document.getElementById('float-btn').classList.toggle('visible',s>600)});
    function toggleMobileMenu(){const m=document.getElementById('mobile-menu');m.classList.toggle('open');document.body.style.overflow=m.classList.contains('open')?'hidden':''}
    function openModal(){const m=document.getElementById('apply-modal');m.classList.remove('hidden');m.classList.add('flex');document.body.style.overflow='hidden';setTimeout(()=>lucide.createIcons(),50)}
    function closeModal(){const m=document.getElementById('apply-modal');m.classList.add('hidden');m.classList.remove('flex');document.body.style.overflow=''}
    document.getElementById('apply-modal').addEventListener('click',e=>{if(e.target===e.currentTarget)closeModal()});
    function showToast(msg){const t=document.getElementById('toast');document.getElementById('toast-msg').textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000)}
    const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible')}),{threshold:.1,rootMargin:'0px 0px -50px 0px'});
    document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
    const tObs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible')}),{threshold:.2});
    const tf=document.getElementById('timeline-fill');if(tf)tObs.observe(tf);

    const P={ft:{name:'Alokito Future Teachers',hrs:43,cost:12000,cr:16.5,demo:true},eng:{name:'Subject Expert — English',hrs:30,cost:10000,cr:14,demo:true},sci:{name:'Subject Expert — Science',hrs:30,cost:10000,cr:14,demo:true},incl:{name:'Subject Expert — Inclusive Ed',hrs:30,cost:10000,cr:14,demo:true},math:{name:'Subject Expert — Mathematics',hrs:30,cost:10000,cr:14,demo:true},lead:{name:'Leadership',hrs:15,cost:5000,cr:5.25,demo:false},ai:{name:'AI in Education',hrs:15,cost:5000,cr:5.25,demo:false},adhd:{name:'ADHD & Special Needs',hrs:15,cost:5000,cr:5.25,demo:false},digital:{name:'Digital Teaching Tools',hrs:15,cost:5000,cr:5.25,demo:false},comm:{name:'Professional Communication',hrs:15,cost:5000,cr:5.25,demo:false},shadow:{name:'Shadow Teaching / Internship',hrs:0,cost:0,cr:15,demo:false},dip:{name:'Diploma Certification',hrs:0,cost:0,cr:0,demo:false}};
    const TP_IDS=['lead','ai','adhd','digital','comm'],SE_IDS=['eng','sci','incl','math'];

    function toggleCheck(id){const c=document.getElementById('chk-'+id);c.checked=!c.checked;updateConfigurator()}

    function updateConfigurator(){
        const sel=[];let hrs=0,cost=0,cr=0,hasSE=false,tpCount=0,hasDemo=false;
        Object.keys(P).forEach(id=>{if(document.getElementById('chk-'+id).checked){const p=P[id];sel.push({name:p.name,cr:p.cr});hrs+=p.hrs;cost+=p.cost;cr+=p.cr;if(SE_IDS.includes(id))hasSE=true;if(TP_IDS.includes(id))tpCount++;if(p.demo)hasDemo=true}});
        const el=document.getElementById('summary-items');
        if(!sel.length){el.innerHTML='<p class="text-text-muted text-sm py-4 text-center">Select programs to see your summary</p>'}
        else{el.innerHTML=sel.map(s=>`<div class="flex items-center justify-between py-1.5 border-b border-warm-border/40"><span class="text-sm text-text-secondary">${s.name}</span><div class="flex items-center gap-2">${s.cr>0?`<span class="text-xs font-medium text-text-muted">${s.cr} cr</span>`:''}<i data-lucide="check-circle-2" class="w-4 h-4 text-accent-orange flex-shrink-0"></i></div></div>`).join('');lucide.createIcons()}
        const cp=document.getElementById('credit-progress'),cc=document.getElementById('credit-count'),cf=document.getElementById('credit-bar-fill');
        if(sel.length){cp.classList.remove('hidden');cc.textContent=(cr%1===0?cr:cr.toFixed(2))+' / 70';cf.style.width=Math.min(100,(cr/70)*100)+'%'}else{cp.classList.add('hidden')}
        document.getElementById('sum-hours').textContent=hrs?hrs+' hours':'0 hours';
        document.getElementById('sum-cost').textContent='৳'+cost.toLocaleString();
        const ds=document.getElementById('demo-summary');hasDemo?ds.classList.remove('hidden'):ds.classList.add('hidden');
        const sh=document.getElementById('chk-shadow').checked;
        document.getElementById('sum-intern').innerHTML=sh?'<span class="text-accent-orange font-semibold">✓ Included</span>':'<span class="text-text-muted">Not included</span>';
        const ft=document.getElementById('chk-ft').checked,dp=document.getElementById('chk-dip').checked,allTP=tpCount===5,qualifies=ft&&hasSE&&allTP&&sh&&dp;
        const cg=document.getElementById('congrats-card'),ab=document.getElementById('config-apply-btn');
        if(qualifies){cg.className='mt-5 celebration';cg.innerHTML=`<div class="relative bg-gradient-to-br from-accent-orange/10 via-accent-gold/10 to-accent-red/10 border border-accent-orange/20 rounded-2xl p-5 text-center overflow-hidden"><div class="confetti-piece" style="left:10%;top:20%;background:#E2804B;animation-delay:0s"></div><div class="confetti-piece" style="left:30%;top:10%;background:#ECBB4E;animation-delay:.1s"></div><div class="confetti-piece" style="left:50%;top:15%;background:#E45D5D;animation-delay:.2s"></div><div class="confetti-piece" style="left:70%;top:20%;background:#E2804B;animation-delay:.3s"></div><div class="confetti-piece" style="left:85%;top:10%;background:#ECBB4E;animation-delay:.15s"></div><p class="text-2xl mb-1">🎉</p><p class="font-bold text-sm text-primary">Congratulations!</p><p class="text-xs text-text-secondary mt-1">You qualify for the <strong>Diploma in Professional Teaching Practice</strong></p></div>`;ab.classList.remove('hidden');document.getElementById('sum-cost').textContent='৳35,000';cc.textContent='70 / 70';cf.style.width='100%'}
        else{cg.className='hidden mt-5';cg.innerHTML='';ab.classList.add('hidden')}
    }

    let ci=0;const trk=document.getElementById('carousel-track'),cds=trk.children,dots=document.getElementById('carousel-dots');
    const gpv=()=>window.innerWidth>=768?2:1,gmi=()=>Math.max(0,cds.length-gpv());
    function uc(){trk.style.transform=`translateX(-${ci*(cds[0].offsetWidth+24)}px)`;dots.innerHTML='';for(let i=0;i<=gmi();i++){const d=document.createElement('button');d.className=`w-2 h-2 rounded-full transition-all ${i===ci?'bg-primary w-6':'bg-warm-border'}`;d.onclick=()=>{ci=i;uc()};dots.appendChild(d)}}
    function moveCarousel(dir){ci=Math.max(0,Math.min(gmi(),ci+dir));uc()}
    uc();window.addEventListener('resize',()=>{ci=Math.min(ci,gmi());uc()});
    let ciInt=setInterval(()=>{ci=ci>=gmi()?0:ci+1;uc()},5000);
    trk.parentElement.addEventListener('mouseenter',()=>clearInterval(ciInt));
    trk.parentElement.addEventListener('mouseleave',()=>{ciInt=setInterval(()=>{ci=ci>=gmi()?0:ci+1;uc()},5000)});

    function toggleFaq(btn){const it=btn.parentElement,ct=it.querySelector('.accordion-content'),ic=btn.querySelector('.accordion-icon'),open=ct.classList.contains('open');document.querySelectorAll('.accordion-content').forEach(c=>c.classList.remove('open'));document.querySelectorAll('.accordion-icon').forEach(i=>i.classList.remove('open'));if(!open){ct.classList.add('open');ic.classList.add('open')}}
    document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeModal();if(document.getElementById('mobile-menu').classList.contains('open'))toggleMobileMenu()}});
    </script>
</body>
